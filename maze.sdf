        <model name="red_danger1"><static>true</static><pose>-4 5 0.5 0 0 0</pose><link name="link"><visual name="v"><geometry><cylinder><radius>0.4</radius><length>1.0</length></cylinder></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual><collision name="c"><geometry><cylinder><radius>0.9</radius><length>1.0</length></cylinder></geometry></collision></link></model>
        <model name="red_danger2"><static>true</static><pose>-7.8 8 0.5 0 0 0</pose><link name="link"><visual name="v"><geometry><cylinder><radius>0.73</radius><length>1.0</length></cylinder></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual><collision name="c"><geometry><cylinder><radius>0.9</radius><length>1.0</length></cylinder></geometry></collision></link></model>
        <model name="red_danger3"><static>true</static><pose> 1.77 -7.44 0.5 0 0 0</pose><link name="link"><visual name="v"><geometry><cylinder><radius>0.73</radius><length>1.0</length></cylinder></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual><collision name="c"><geometry><cylinder><radius>0.9</radius><length>1.0</length></cylinder></geometry></collision></link></model>
        <model name="red_danger4"><static>true</static><pose>-2.85 -7.21 0.5 0 0 0</pose><link name="link"><visual name="v"><geometry><cylinder><radius>0.73</radius><length>1.0</length></cylinder></geometry><material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material></visual><collision name="c"><geometry><cylinder><radius>0.9</radius><length>1.0</length></cylinder></geometry></collision></link></model>




